{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Sample W3C DTCG tokens.json — mirrors the 2-tier (semantic + comp) architecture from design-component-builder/examples/tokens.css. Tailwind defaults (blue.600 primary, slate neutrals).",

  "color": {
    "primary": {
      "default": {
        "$value": "#2563eb",
        "$type": "color",
        "$description": "Primary action color (Tailwind blue.600). Used on buttons, links, focused borders."
      },
      "dark": {
        "$value": "#1d4ed8",
        "$type": "color",
        "$description": "Primary on hover (blue.700)."
      },
      "darker": {
        "$value": "#1e40af",
        "$type": "color",
        "$description": "Primary on active / pressed (blue.800)."
      },
      "soft": {
        "$value": "#dbeafe",
        "$type": "color",
        "$description": "Primary tint background — selected rows, info banners (blue.100)."
      }
    },
    "text": {
      "primary": {
        "$value": "#0f172a",
        "$type": "color",
        "$description": "Body and heading text (slate.900)."
      },
      "secondary": {
        "$value": "#475569",
        "$type": "color",
        "$description": "Secondary / meta text (slate.600)."
      },
      "tertiary": {
        "$value": "#94a3b8",
        "$type": "color",
        "$description": "Placeholder and hint text (slate.400)."
      },
      "on-bgcolor": {
        "$value": "#ffffff",
        "$type": "color",
        "$description": "Text drawn on filled brand or status backgrounds (white)."
      },
      "disable": {
        "$value": "#cbd5e1",
        "$type": "color",
        "$description": "Disabled label / value text (slate.300)."
      },
      "link": {
        "$value": "#2563eb",
        "$type": "color",
        "$description": "Inline link text colour (blue.600)."
      }
    },
    "border": {
      "default": {
        "$value": "#e2e8f0",
        "$type": "color",
        "$description": "Default control / divider border (slate.200)."
      },
      "strong": {
        "$value": "#cbd5e1",
        "$type": "color",
        "$description": "Emphasised divider (slate.300)."
      },
      "focus": {
        "$value": "#2563eb",
        "$type": "color",
        "$description": "Focused input border."
      },
      "error": {
        "$value": "#dc2626",
        "$type": "color",
        "$description": "Invalid input border (red.600)."
      }
    },
    "surface": {
      "base": {
        "$value": "#ffffff",
        "$type": "color",
        "$description": "Card, modal, page background."
      },
      "raised": {
        "$value": "#ffffff",
        "$type": "color",
        "$description": "Floating panel — popover, dropdown."
      },
      "sunken": {
        "$value": "#f8fafc",
        "$type": "color",
        "$description": "App shell / page bg behind cards (slate.50)."
      },
      "muted": {
        "$value": "#f1f5f9",
        "$type": "color",
        "$description": "Subtle row hover, tag bg (slate.100)."
      }
    },
    "status": {
      "success": {
        "$value": "#16a34a",
        "$type": "color",
        "$description": "Success icon / accent (green.600)."
      },
      "warning": {
        "$value": "#d97706",
        "$type": "color",
        "$description": "Warning icon / accent (amber.600)."
      },
      "error": {
        "$value": "#dc2626",
        "$type": "color",
        "$description": "Error icon / accent (red.600)."
      },
      "info": {
        "$value": "#2563eb",
        "$type": "color",
        "$description": "Info icon / accent (blue.600)."
      }
    }
  },

  "radius": {
    "none": { "$value": "0px",     "$type": "dimension", "$description": "Edge-to-edge surfaces." },
    "sm":   { "$value": "4px",     "$type": "dimension", "$description": "Badge, tag, checkbox." },
    "md":   { "$value": "8px",     "$type": "dimension", "$description": "Button, input, card (default)." },
    "lg":   { "$value": "12px",    "$type": "dimension", "$description": "Modal, large card." },
    "xl":   { "$value": "16px",    "$type": "dimension", "$description": "Hero card, feature surface." },
    "pill": { "$value": "9999px",  "$type": "dimension", "$description": "Pill button, avatar, switch." }
  },

  "space": {
    "xs":  { "$value": "4px",  "$type": "dimension", "$description": "Hairline gap, icon-text gap." },
    "sm":  { "$value": "8px",  "$type": "dimension", "$description": "Tight stack, badge padding, compact button/input py." },
    "md":  { "$value": "16px", "$type": "dimension", "$description": "Card padding, button px (default), standard gap." },
    "lg":  { "$value": "24px", "$type": "dimension", "$description": "Comfortable card padding, modal padding, section gap." },
    "xl":  { "$value": "32px", "$type": "dimension", "$description": "Large card, section vertical rhythm." },
    "2xl": { "$value": "48px", "$type": "dimension", "$description": "Hero spacing, top-level page rhythm." }
  },

  "shadow": {
    "sm": {
      "$value": "0 1px 2px 0 rgba(15,23,42,0.05)",
      "$type": "shadow",
      "$description": "Subtle lift — card at rest."
    },
    "md": {
      "$value": "0 4px 8px 0 rgba(15,23,42,0.12)",
      "$type": "shadow",
      "$description": "Button, raised card."
    },
    "lg": {
      "$value": "0 10px 15px -3px rgba(15,23,42,0.10), 0 4px 6px -4px rgba(15,23,42,0.10)",
      "$type": "shadow",
      "$description": "Modal, popover."
    },
    "focus": {
      "$value": "0 0 0 3px rgba(37,99,235,0.35)",
      "$type": "shadow",
      "$description": "Focus ring (WCAG 2.4.7)."
    }
  },

  "font": {
    "sans": {
      "$value": "Inter, system-ui, sans-serif",
      "$type": "fontFamily",
      "$description": "Default UI font stack."
    },
    "mono": {
      "$value": "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace",
      "$type": "fontFamily",
      "$description": "Code, numeric tables."
    }
  },

  "size": {
    "xs":  { "$value": "12px", "$type": "dimension", "$description": "Caption, badge." },
    "sm":  { "$value": "14px", "$type": "dimension", "$description": "Secondary label, helper text." },
    "md":  { "$value": "16px", "$type": "dimension", "$description": "Body, input, button (default)." },
    "lg":  { "$value": "18px", "$type": "dimension", "$description": "Subhead." },
    "xl":  { "$value": "20px", "$type": "dimension", "$description": "Card title." },
    "2xl": { "$value": "24px", "$type": "dimension", "$description": "Page heading." }
  },

  "weight": {
    "regular":  { "$value": 400, "$type": "fontWeight", "$description": "Body." },
    "medium":   { "$value": 500, "$type": "fontWeight", "$description": "Label, secondary action." },
    "semibold": { "$value": 600, "$type": "fontWeight", "$description": "Button, heading." },
    "bold":     { "$value": 700, "$type": "fontWeight", "$description": "Emphasis, page title." }
  },

  "leading": {
    "tight":   { "$value": 1.25, "$type": "number", "$description": "Heading line-height." },
    "normal":  { "$value": 1.5,  "$type": "number", "$description": "Body line-height (default)." },
    "relaxed": { "$value": 1.75, "$type": "number", "$description": "Long-form reading." }
  },

  "tracking": {
    "tight":  { "$value": "-0.01em", "$type": "dimension", "$description": "Display headlines." },
    "normal": { "$value": "0em",     "$type": "dimension", "$description": "Body default." },
    "wide":   { "$value": "0.05em",  "$type": "dimension", "$description": "All-caps labels, eyebrow text." }
  },

  "a11y": {
    "touch-min": {
      "$value": "44px",
      "$type": "dimension",
      "$description": "Minimum hit-target size (WCAG 2.5.5)."
    },
    "focus-ring": {
      "$value": "{shadow.focus}",
      "$type": "shadow",
      "$description": "Default focus outline alternative — alias of shadow.focus."
    }
  },

  "comp": {
    "btn-bg": {
      "$value": "{color.primary.default}",
      "$type": "color",
      "$description": "Button background — resting."
    },
    "btn-bg-hover": {
      "$value": "{color.primary.dark}",
      "$type": "color",
      "$description": "Button background on hover."
    },
    "btn-bg-active": {
      "$value": "{color.primary.darker}",
      "$type": "color",
      "$description": "Button background on press."
    },
    "btn-text": {
      "$value": "{color.text.on-bgcolor}",
      "$type": "color",
      "$description": "Button label colour."
    },
    "btn-radius": {
      "$value": "{radius.md}",
      "$type": "dimension",
      "$description": "Button corner radius."
    },
    "btn-shadow": {
      "$value": "{shadow.md}",
      "$type": "shadow",
      "$description": "Button resting shadow."
    },
    "input-bg": {
      "$value": "{color.surface.base}",
      "$type": "color",
      "$description": "Input background."
    },
    "input-border": {
      "$value": "{color.border.default}",
      "$type": "color",
      "$description": "Input border — resting."
    },
    "input-border-focus": {
      "$value": "{color.border.focus}",
      "$type": "color",
      "$description": "Input border — focused."
    },
    "input-border-error": {
      "$value": "{color.border.error}",
      "$type": "color",
      "$description": "Input border — invalid."
    },
    "input-radius": {
      "$value": "{radius.md}",
      "$type": "dimension",
      "$description": "Input corner radius."
    },
    "input-text": {
      "$value": "{color.text.primary}",
      "$type": "color",
      "$description": "Input value text colour."
    },
    "input-placeholder": {
      "$value": "{color.text.tertiary}",
      "$type": "color",
      "$description": "Input placeholder colour."
    },
    "card-bg": {
      "$value": "{color.surface.base}",
      "$type": "color",
      "$description": "Card background."
    },
    "card-border": {
      "$value": "{color.border.default}",
      "$type": "color",
      "$description": "Card border."
    },
    "card-radius": {
      "$value": "{radius.lg}",
      "$type": "dimension",
      "$description": "Card corner radius."
    },
    "card-padding": {
      "$value": "{space.lg}",
      "$type": "dimension",
      "$description": "Card inner padding."
    }
  }
}
